{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pccs-lens",
  "compatibility_date": "2026-03-19",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./build",
    "not_found_handling": "404-page"
  },
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true
  }
}
