<script>
  import SVGWrapper from '$lib/demo/SVGWrapper.svelte'
  import LuckieshMossFigure from '$lib/demo/subjective-color/LuckieshMossFigure.svelte'
  import SkinnerFigure from '$lib/demo/subjective-color/SkinnerFigure.svelte'
