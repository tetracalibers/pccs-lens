<AnalyzedPalette pccs={["ltg10", "g10", "dkg10"]} />
:::
:::TermCard
<AnalyzedPalette pccs={["dk4", "lt6"]} />
:::
:::TermCard
<AnalyzedPalette pccs={["v18", "b18", "W"]} />
:::
