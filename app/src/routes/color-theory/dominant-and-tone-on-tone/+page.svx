:::TermCard
<AnalyzedPalette pccs={["dp12", "dp14", "dp8", "dp20"]} />
:::
:::TermCard
<AnalyzedPalette pccs={["p2", "ltg18"]} />
:::
:::TermCard
<AnalyzedPalette pccs={["p2", "lt24"]} />
:::
:::TermCard
<AnalyzedPalette pccs={["v3", "v6", "v11", "b18", "v22", "b24"]} />
:::
